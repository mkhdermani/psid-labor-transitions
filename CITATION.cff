    given-names: "Mohsen"
    email: mkhdermani@gmail.com
keywords:
  - labour economics
  - panel data
  - PSID
  - NLSY
  - CPS
  - transition rates
  - Stata
  - R
license: MIT
date-released: "2026-06-02"
